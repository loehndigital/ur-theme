{%- comment -%}
  Uncle Rusty's – Warum Hero (Text + Bild)
  Platzierung: sections/warum-hero.liquid
{%- endcomment -%}

{%- assign ac  = section.settings.accent_color | default: '#c4622d' -%}
{%- assign ar  = ac | color_extract: 'red'   -%}
{%- assign ag  = ac | color_extract: 'green' -%}
{%- assign ab  = ac | color_extract: 'blue'  -%}
{%- assign sh  = section.settings.img_shadow | default: 65 | divided_by: 100.0 -%}
{%- assign sha = sh | times: 0.22 | round: 3 -%}
{%- assign shb = sh | times: 0.10 | round: 3 -%}
{%- assign shc = sh | times: 0.08 | round: 3 -%}
{%- assign img_alt = section.settings.image_alt | default: 'Uncle Rustys Hundefutter' -%}

<style>
/* ╔══════════════════════════════════╗
   ║  UNCLE RUSTY'S – WARUM HERO     ║
   ╚══════════════════════════════════╝ */

#wh-{{ section.id }} {
  --wh-accent: {{ section.settings.accent_color | default: '#c4622d' }};
  --wh-bg:     {{ section.settings.bg_color     | default: '#EBE6D9' }};
  --wh-card:   {{ section.settings.card_color   | default: '#fffaf3' }};
  --wh-dark:   {{ section.settings.dark_color   | default: '#3d2510' }};
  --wh-text:   #2c1a0e;
  --wh-text2:  #7a5c3a;
  --wh-dim:    #9a7c5a;
  --wh-border: rgba(60,35,15,0.12);

  position: relative;      /* Pfoten-Container braucht positioned parent */
  padding: 64px 20px;
  font-family: inherit;
  {%- if section.settings.bg_style == 'transparent' -%}
  background: transparent;
  {%- else -%}
  background-color: var(--wh-bg);
  {%- endif -%}
}
@media(min-width:768px)  { #wh-{{ section.id }} { padding: 96px 28px  } }
@media(min-width:1024px) { #wh-{{ section.id }} { padding: 120px 48px } }

/* ── Pfoten-Pattern Container (via JS befüllt) ── */
#wh-{{ section.id }} .wh-paws {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
}
#wh-{{ section.id }} .wh-paws svg {
  width: 100%;
  height: 100%;
  fill: var(--wh-dark);
  display: block;
}

/* ══ Layout ═══════════════════════ */
#wh-{{ section.id }} .wh-inner {
  position: relative;
  z-index: 1;
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr;
  gap: 44px;
  align-items: center;
}
@media(min-width:768px)  { #wh-{{ section.id }} .wh-inner { grid-template-columns: 1fr 1fr;   gap: 56px } }
@media(min-width:1024px) { #wh-{{ section.id }} .wh-inner { grid-template-columns: 55fr 45fr; gap: 80px } }

{%- if section.settings.mobile_image_order == 'above' -%}
@media(max-width:767px) {
  #wh-{{ section.id }} .wh-img-col { order: -1 }
}
{%- endif -%}

{%- if section.settings.image_side == 'left' -%}
@media(min-width:768px) {
  #wh-{{ section.id }} .wh-inner   { grid-template-columns: 45fr 55fr }
  #wh-{{ section.id }} .wh-img-col { order: -1 }
}
{%- endif -%}

#wh-{{ section.id }} .wh-text-col { min-width: 0 }
#wh-{{ section.id }} .wh-img-col  { min-width: 0; position: relative }

/* ══ Eyebrow ══════════════════════ */
#wh-{{ section.id }} .wh-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 5px 14px;
  border-radius: 999px;
  background: rgba({{ ar }},{{ ag }},{{ ab }},0.10);
  border: 1px solid rgba({{ ar }},{{ ag }},{{ ab }},0.28);
  color: var(--wh-accent);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .18em;
  text-transform: uppercase;
  margin-bottom: 20px;
}
@media(min-width:768px) { #wh-{{ section.id }} .wh-eyebrow { font-size: 12px; margin-bottom: 28px } }

/* ══ Headline ═════════════════════ */
#wh-{{ section.id }} .wh-h2 {
  color: var(--wh-dark);
  font-size: 28px;
  font-weight: 800;
  line-height: 1.1;
  margin: 0;
  letter-spacing: -.02em;
}
@media(min-width:768px)  { #wh-{{ section.id }} .wh-h2 { font-size: 40px } }
@media(min-width:1024px) { #wh-{{ section.id }} .wh-h2 { font-size: 50px } }

#wh-{{ section.id }} .wh-h2-acc {
  display: block;
  font-style: italic;
  color: var(--wh-accent);
  margin-bottom: 28px;
}
@media(min-width:768px)  { #wh-{{ section.id }} .wh-h2-acc { margin-bottom: 36px } }
@media(min-width:1024px) { #wh-{{ section.id }} .wh-h2-acc { margin-bottom: 40px } }

/* ══ Body + Statement ═════════════ */
#wh-{{ section.id }} .wh-body {
  color: var(--wh-text2);
  font-size: 14px;
  line-height: 1.8;
  margin: 0 0 20px;
  max-width: 560px;
}
@media(min-width:768px) { #wh-{{ section.id }} .wh-body { font-size: 16px; margin-bottom: 24px } }

#wh-{{ section.id }} .wh-stmt {
  color: var(--wh-text);
  font-size: 15px;
  font-weight: 700;
  line-height: 1.5;
  margin: 0 0 32px;
  max-width: 560px;
}
@media(min-width:768px) { #wh-{{ section.id }} .wh-stmt { font-size: 17px; margin-bottom: 40px } }
#wh-{{ section.id }} .wh-stmt-acc { color: var(--wh-accent) }

/* ══ Badges ════════════════════════ */
#wh-{{ section.id }} .wh-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 32px;
}
@media(min-width:768px) { #wh-{{ section.id }} .wh-badges { gap: 12px; margin-bottom: 40px } }

#wh-{{ section.id }} .wh-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 9px 16px;
  border-radius: 12px;
  background: rgba(255,255,255,0.65);
  backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
  border: 1px solid var(--wh-border);
  box-shadow: 0 2px 8px rgba(60,35,15,.07);
  color: var(--wh-text);
  font-size: 13px;
  font-weight: 600;
  transition: background .25s, box-shadow .25s, transform .2s;
}
#wh-{{ section.id }} .wh-badge:hover {
  background: rgba(255,255,255,0.92);
  box-shadow: 0 4px 16px rgba(60,35,15,.12);
  transform: translateY(-1px);
}
#wh-{{ section.id }} .wh-badge-icon { font-size: 15px; line-height: 1; flex-shrink: 0 }

/* ══ Tagline ═══════════════════════ */
#wh-{{ section.id }} .wh-tagline {
  color: var(--wh-dim);
  font-size: 12px;
  font-style: italic;
  line-height: 1.75;
  max-width: 520px;
  padding: 0 0 0 14px;
  border-left: 2px solid rgba({{ ar }},{{ ag }},{{ ab }},0.28);
  margin: 0;
}
@media(min-width:768px) { #wh-{{ section.id }} .wh-tagline { font-size: 13px } }

/* ══ CTA-Button ════════════════════ */
#wh-{{ section.id }} .wh-cta {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin-top: 32px;
  padding: 14px 28px;
  border-radius: 12px;
  background: var(--wh-accent);
  color: #fff;
  font-size: 15px;
  font-weight: 700;
  text-decoration: none;
  box-shadow: 0 4px 16px rgba({{ ar }},{{ ag }},{{ ab }},0.30);
  transition: opacity .2s, transform .2s, box-shadow .2s;
  letter-spacing: .02em;
}
#wh-{{ section.id }} .wh-cta:hover {
  opacity: .9;
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba({{ ar }},{{ ag }},{{ ab }},0.40);
}

/* ══ Bild-Spalte ═══════════════════ */
#wh-{{ section.id }} .wh-glow {
  position: absolute;
  top: -40px; right: -40px;
  width: 220px; height: 220px;
  border-radius: 50%;
  background: rgba({{ ar }},{{ ag }},{{ ab }},0.14);
  filter: blur(70px);
  pointer-events: none;
  z-index: 0;
}
#wh-{{ section.id }} .wh-glow-b {
  position: absolute;
  bottom: -30px; left: -20px;
  width: 160px; height: 160px;
  border-radius: 50%;
  background: rgba({{ ar }},{{ ag }},{{ ab }},0.08);
  filter: blur(50px);
  pointer-events: none;
  z-index: 0;
}

/* Glassmorphism-Frame – Schatten via img_shadow-Einstellung */
#wh-{{ section.id }} .wh-img-frame {
  position: relative;
  z-index: 1;
  border-radius: 20px;
  overflow: hidden;
  background: rgba(255,255,255,0.50);
  backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255,255,255,0.80);
  box-shadow:
    0 24px 64px rgba(60,35,15,{{ sha }}),
    0 8px  24px rgba(60,35,15,{{ shb }}),
    0 48px 96px rgba({{ ar }},{{ ag }},{{ ab }},{{ shc }}),
    inset 0 1px 0 rgba(255,255,255,0.90);
}

#wh-{{ section.id }} .wh-img {
  width: 100%;
  aspect-ratio: 4 / 5;
  object-fit: cover;
  display: block;
}
@media(min-width:768px) { #wh-{{ section.id }} .wh-img { aspect-ratio: 3 / 4 } }

#wh-{{ section.id }} .wh-img-ph {
  aspect-ratio: 4 / 5;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 10px;
  background: linear-gradient(135deg,
    rgba({{ ar }},{{ ag }},{{ ab }},0.05) 0%,
    rgba(245,237,224,0.40) 100%);
  color: var(--wh-dim);
  font-size: 13px;
  font-style: italic;
  padding: 32px;
  text-align: center;
}
@media(min-width:768px) { #wh-{{ section.id }} .wh-img-ph { aspect-ratio: 3 / 4 } }
#wh-{{ section.id }} .wh-img-ph-icon { font-size: 32px; opacity: .4 }

#wh-{{ section.id }} .wh-img-label {
  position: absolute;
  bottom: 16px;
  left: 50%;
  transform: translateX(-50%);
  white-space: nowrap;
  padding: 6px 18px;
  border-radius: 999px;
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba({{ ar }},{{ ag }},{{ ab }},0.20);
  color: var(--wh-accent);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  box-shadow: 0 2px 12px rgba(60,35,15,.10);
}
</style>

<section id="wh-{{ section.id }}" aria-label="{{ section.settings.headline | escape }}">
  <div class="wh-inner">

    <!-- TEXT -->
    <div class="wh-text-col">

      {%- if section.settings.eyebrow != blank -%}
        <p class="wh-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h2 class="wh-h2">
        {{- section.settings.headline -}}
        {%- if section.settings.headline_acc != blank -%}
          <em class="wh-h2-acc">{{ section.settings.headline_acc }}</em>
        {%- endif -%}
      </h2>

      {%- if section.settings.body != blank -%}
        <p class="wh-body">{{ section.settings.body }}</p>
      {%- endif -%}

      {%- if section.settings.stmt_pre != blank or section.settings.stmt_acc != blank -%}
        <p class="wh-stmt">
          {{- section.settings.stmt_pre -}}
          {%- if section.settings.stmt_acc != blank -%}
            <span class="wh-stmt-acc"> {{ section.settings.stmt_acc }}</span>
          {%- endif -%}
        </p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="wh-badges">
          {%- for block in section.blocks -%}
            {%- if block.type == 'badge' -%}
              <span class="wh-badge" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != blank -%}
                  <span class="wh-badge-icon" aria-hidden="true">{{ block.settings.icon }}</span>
                {%- endif -%}
                {{ block.settings.label }}
              </span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.tagline != blank -%}
        <p class="wh-tagline">{{ section.settings.tagline }}</p>
      {%- endif -%}

      {%- if section.settings.cta_text != blank and section.settings.cta_url != blank -%}
        <a href="{{ section.settings.cta_url }}" class="wh-cta">
          {{ section.settings.cta_text }}
          <span aria-hidden="true">→</span>
        </a>
      {%- endif -%}

    </div><!-- /.wh-text-col -->

    <!-- BILD -->
    <div class="wh-img-col">
      <div class="wh-glow"   aria-hidden="true"></div>
      <div class="wh-glow-b" aria-hidden="true"></div>

      <div class="wh-img-frame">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 900 }}"
            srcset="
              {{ section.settings.image | image_url: width: 400 }}  400w,
              {{ section.settings.image | image_url: width: 700 }}  700w,
              {{ section.settings.image | image_url: width: 900 }}  900w,
              {{ section.settings.image | image_url: width: 1200 }} 1200w"
            sizes="(min-width:1024px) 45vw, (min-width:768px) 50vw, 95vw"
            alt="{{ img_alt | escape }}"
            class="wh-img"
            loading="lazy"
            decoding="async"
          >
        {%- else -%}
          <div class="wh-img-ph">
            <span class="wh-img-ph-icon">🖼</span>
            Bild im Editor hinzufügen →
          </div>
        {%- endif -%}

        {%- if section.settings.img_label != blank -%}
          <span class="wh-img-label">{{ section.settings.img_label }}</span>
        {%- endif -%}
      </div>

    </div><!-- /.wh-img-col -->

  </div><!-- /.wh-inner -->
</section>

<script>
(function(){
  var BG_STYLE = '{{ section.settings.bg_style | default: "paw" }}';

  /* ── Original Uncle Rusty's Pfoten-Pfade ── */
  var PAW_SVG_OPEN  = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 110.51 102.33" width="100%" height="100%">';
  var PAW_SVG_PATHS =
    '<path d="m40.23,34.23c-2.88-.64-4.71-2.1-6.03-4.18-1.41-2.21-2.07-4.66-2.48-7.17-.36-2.15-.57-4.32-.38-6.49.15-1.71.35-3.42.55-5.13.28-2.39,1.19-4.59,2.34-6.71.34-.63.81-1.2,1.26-1.76C37.25.64,39.68-.12,42.44.01c2.24.1,4.33.76,6.25,1.87,3.65,2.11,6.09,5.18,7.8,8.81.99,2.1,1.64,4.29,1.83,6.57.12,1.4.06,2.82-.04,4.22-.14,1.92-.65,3.78-1.51,5.53-1.68,3.39-4.39,5.63-8.32,6.53-2.17.5-4.33.95-6.58.86-.65-.03-1.3-.13-1.63-.17Z"/>' +
    '<path d="m88.66,9.84c1.13.49,2.38.92,3.51,1.55,2.25,1.25,3.34,3.18,3.6,5.62.2,1.81.17,3.59-.27,5.35-.4,1.63-.76,3.28-1.31,4.86-.79,2.29-1.9,4.47-3.21,6.54-1.78,2.81-3.83,5.43-6.78,7.28-1.87,1.17-3.91,1.69-6.18,1.49-1.57-.14-3.01-.65-4.27-1.43-1.63-1.01-3.17-2.17-4.66-3.35-1.98-1.56-3.05-3.63-3.57-6-.53-2.39-.25-4.72.45-7.03,1.45-4.76,4.48-8.48,8.67-11.4,3.05-2.12,6.45-3.47,10.27-3.65,1.21-.06,2.43.1,3.76.16Z"/>' +
    '<path d="m84.32,64.9c-.45-3.11.14-6,1.51-8.74,1.94-3.88,4.89-6.87,9.07-8.71,1.46-.64,3.01-1.03,4.64-1.14,2.64-.19,5.04.31,7.14,1.87,1.5,1.11,2.52,2.55,3.1,4.26,1.64,4.83.39,9.2-2.46,13.28-2.08,2.97-4.86,5.21-8.41,6.48-3.78,1.35-7.48,1.33-10.84-1.1-1.68-1.22-2.8-2.83-3.35-4.77-.14-.5-.27-.99-.39-1.42Z"/>' +
    '<path d="m.38,29c1.03-3.8,3.42-6.38,7.6-7.29,1.19-.26,2.39-.21,3.62-.07,2.03.24,3.89.92,5.57,1.93,4.65,2.78,7.46,6.79,8.53,11.86.35,1.67.34,3.36,0,5.07-.47,2.33-1.41,4.39-3.33,5.97-1.92,1.58-4.19,2.26-6.72,2.19-2.5-.06-4.77-.79-6.85-2.07-4.69-2.91-7.52-6.98-8.54-12.16-.36-1.81-.34-3.62.13-5.43Z"/>' +
    '<path d="m46.49,85.7c-9.89-4.95-35.88,4.08-32.7-14.2,3.82-22.02,36.18-27.99,48.11-22.35,22.27,10.54,16.17,44.5,10.13,50.1-11.61,10.75-17.97-9.77-25.53-13.55Z"/>';
  var PAW_SVG_CLOSE = '</svg>';

  function buildPaws(sec){
    if(BG_STYLE !== 'paw') return;

    /* Alten Container entfernen (Editor-Reload) */
    var old = sec.querySelector('.wh-paws');
    if(old) old.remove();

    var ctn = document.createElement('div');
    ctn.className = 'wh-paws';
    ctn.setAttribute('aria-hidden','true');

    /* 18 zufällig positionierte Pfoten */
    for(var i = 0; i < 18; i++){
      var el  = document.createElement('div');
      var x   = (Math.random() * 112 - 6).toFixed(1);   /* -6% bis 106% */
      var y   = (Math.random() * 112 - 6).toFixed(1);
      var rot = (Math.random() * 360).toFixed(0);
      var sz  = (28 + Math.random() * 64).toFixed(0);   /* 28px – 92px */
      var op  = (0.03 + Math.random() * 0.08).toFixed(3); /* 0.03 – 0.11 */
      el.style.cssText =
        'position:absolute;left:'+x+'%;top:'+y+'%;' +
        'width:'+sz+'px;height:'+sz+'px;' +
        'opacity:'+op+';transform:rotate('+rot+'deg);';
      el.innerHTML = PAW_SVG_OPEN + PAW_SVG_PATHS + PAW_SVG_CLOSE;
      ctn.appendChild(el);
    }

    sec.insertBefore(ctn, sec.firstChild);
  }

  function init(){
    var sec = document.getElementById('wh-{{ section.id }}');
    if(sec) buildPaws(sec);
  }

  init();

  /* Shopify Editor: nach section-Reload neu befüllen */
  document.addEventListener('shopify:section:load', function(e){
    var sec = e.target && e.target.querySelector('#wh-{{ section.id }}');
    if(!sec) sec = document.getElementById('wh-{{ section.id }}');
    if(sec) buildPaws(sec);
  });
})();
</script>

{% schema %}
{
  "name": "Warum Hero",
  "settings": [
    {
      "type": "header",
      "content": "Headline & Texte"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow-Pill (über Headline)",
      "default": "+ WARUM UNCLE RUSTY'S"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline Zeile 1",
      "default": "Gesundheit beginnt nicht beim Tierarzt."
    },
    {
      "type": "text",
      "id": "headline_acc",
      "label": "Headline Zeile 2 – kursiv, Akzentfarbe",
      "default": "Sie beginnt im Napf."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Fließtext",
      "default": "Viele Hundefutter klingen gut, aber ein Blick auf die Zutatenliste erzählt eine andere Geschichte. Unklare Deklarationen, unnötige Zusatzstoffe und schwer nachvollziehbare Rezepturen."
    },
    {
      "type": "text",
      "id": "stmt_pre",
      "label": "Statement – normaler Teil",
      "default": "Darum verfolgen wir einen einfachen Ansatz:"
    },
    {
      "type": "text",
      "id": "stmt_acc",
      "label": "Statement – Akzentfarbe-Teil",
      "default": "Zutaten, die man versteht."
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Kursive Tagline (unten, mit Akzent-Linie links)",
      "default": "Der Napf entscheidet jeden Tag über Energie, Verdauung und Wohlbefinden. Darum entwickeln wir Hundefutter, das diese Grundlage ernst nimmt."
    },
    {
      "type": "header",
      "content": "Call-to-Action (optional)"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button-Text",
      "info": "Leer lassen = Button ausblenden"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button-Link"
    },
    {
      "type": "header",
      "content": "Bild"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bild (rechte Spalte)"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Alt-Text",
      "default": "Uncle Rustys Hundefutter"
    },
    {
      "type": "text",
      "id": "img_label",
      "label": "Bild-Label (optional, unten mittig als Pill)",
      "info": "z.B. \"Naturrein seit 2018\" – leer lassen zum Ausblenden"
    },
    {
      "type": "range",
      "id": "img_shadow",
      "label": "Bild-Schatten Intensität",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 65,
      "unit": "%"
    },
    {
      "type": "select",
      "id": "mobile_image_order",
      "label": "Bild-Position (Mobil)",
      "options": [
