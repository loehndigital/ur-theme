<script>
(function(){

  /* ══ Originale Uncle Rusty's Paw-SVG-Pfade ══════════════════════════ */
  var PAW_OPEN  = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 110.51 102.33" width="100%" height="100%">';
  var PAW_PATHS =
    '<path d="m40.23,34.23c-2.88-.64-4.71-2.1-6.03-4.18-1.41-2.21-2.07-4.66-2.48-7.17-.36-2.15-.57-4.32-.38-6.49.15-1.71.35-3.42.55-5.13.28-2.39,1.19-4.59,2.34-6.71.34-.63.81-1.2,1.26-1.76C37.25.64,39.68-.12,42.44.01c2.24.1,4.33.76,6.25,1.87,3.65,2.11,6.09,5.18,7.8,8.81.99,2.1,1.64,4.29,1.83,6.57.12,1.4.06,2.82-.04,4.22-.14,1.92-.65,3.78-1.51,5.53-1.68,3.39-4.39,5.63-8.32,6.53-2.17.5-4.33.95-6.58.86-.65-.03-1.3-.13-1.63-.17Z"/>' +
    '<path d="m88.66,9.84c1.13.49,2.38.92,3.51,1.55,2.25,1.25,3.34,3.18,3.6,5.62.2,1.81.17,3.59-.27,5.35-.4,1.63-.76,3.28-1.31,4.86-.79,2.29-1.9,4.47-3.21,6.54-1.78,2.81-3.83,5.43-6.78,7.28-1.87,1.17-3.91,1.69-6.18,1.49-1.57-.14-3.01-.65-4.27-1.43-1.63-1.01-3.17-2.17-4.66-3.35-1.98-1.56-3.05-3.63-3.57-6-.53-2.39-.25-4.72.45-7.03,1.45-4.76,4.48-8.48,8.67-11.4,3.05-2.12,6.45-3.47,10.27-3.65,1.21-.06,2.43.1,3.76.16Z"/>' +
    '<path d="m84.32,64.9c-.45-3.11.14-6,1.51-8.74,1.94-3.88,4.89-6.87,9.07-8.71,1.46-.64,3.01-1.03,4.64-1.14,2.64-.19,5.04.31,7.14,1.87,1.5,1.11,2.52,2.55,3.1,4.26,1.64,4.83.39,9.2-2.46,13.28-2.08,2.97-4.86,5.21-8.41,6.48-3.78,1.35-7.48,1.33-10.84-1.1-1.68-1.22-2.8-2.83-3.35-4.77-.14-.5-.27-.99-.39-1.42Z"/>' +
    '<path d="m.38,29c1.03-3.8,3.42-6.38,7.6-7.29,1.19-.26,2.39-.21,3.62-.07,2.03.24,3.89.92,5.57,1.93,4.65,2.78,7.46,6.79,8.53,11.86.35,1.67.34,3.36,0,5.07-.47,2.33-1.41,4.39-3.33,5.97-1.92,1.58-4.19,2.26-6.72,2.19-2.5-.06-4.77-.79-6.85-2.07-4.69-2.91-7.52-6.98-8.54-12.16-.36-1.81-.34-3.62.13-5.43Z"/>' +
    '<path d="m46.49,85.7c-9.89-4.95-35.88,4.08-32.7-14.2,3.82-22.02,36.18-27.99,48.11-22.35,22.27,10.54,16.17,44.5,10.13,50.1-11.61,10.75-17.97-9.77-25.53-13.55Z"/>';
  var PAW_CLOSE = '</svg>';

  /* ══ Paw-Pattern spawnen ═════════════════════════════════════════════
     Nur bei bg_style = paw_light oder paw_dark.
     Fill-Farbe: dunkel auf hellem Bg / hell auf dunklem Bg.
  ════════════════════════════════════════════════════════════════════ */
  function buildPaws(sec){
    var style = sec.getAttribute('data-zb-bg') || '';
    if(style !== 'paw_light' && style !== 'paw_dark') return;

    var ctn = sec.querySelector('.zb-paws-ctn');
    if(!ctn) return;
    ctn.innerHTML = '';

    /* Pfoten-Farbe: auf hellem Bg dunkel, auf dunklem Bg hell */
    var fillColor = style === 'paw_dark' ? '#f5ede0' : '#3d2510';

    for(var i = 0; i < 18; i++){
      var el  = document.createElement('div');
      var x   = (5 + Math.random() * 85).toFixed(1);   /* 5–90 % → kein harter Abschnitt am Rand */
      var y   = (5 + Math.random() * 85).toFixed(1);   /* 5–90 % → kein harter Abschnitt am Rand */
      var rot = (Math.random() * 360).toFixed(0);
      var sz  = (24 + Math.random() * 36).toFixed(0);  /* 24–60 px → weniger Überlappung */
      var op  = (0.04 + Math.random() * 0.08).toFixed(3);
      el.style.cssText =
        'position:absolute;left:'+x+'%;top:'+y+'%;' +
        'width:'+sz+'px;height:'+sz+'px;' +
        'opacity:'+op+';transform:rotate('+rot+'deg);pointer-events:none;';
      /* Fill-Farbe inline in SVG injizieren */
      el.innerHTML = PAW_OPEN.replace('>', ' fill="'+fillColor+'">') + PAW_PATHS + PAW_CLOSE;
      ctn.appendChild(el);
    }
  }

  /* ══ Parallax ════════════════════════════════════════════════════════
     Exakt wie in der Landing Page:
       center   = rect.top + rect.height/2 - window.innerHeight/2
       offsetY  = center * factor
     Desktop-Faktoren: Glas 1 = -0.04, Glas 2 = +0.06, Glas 3 = -0.035
     Mobile-Faktoren:  Glas 1 = -0.02, Glas 2 = +0.03, Glas 3 = -0.018
     Glas 2 Mitte hat positiven Faktor → scrollt in entgegengesetzte Richtung
  ════════════════════════════════════════════════════════════════════ */
  function initParallax(sec){

    /* Desktop */
    var desktopWraps = sec.querySelectorAll('.zb-gd-1,.zb-gd-2,.zb-gd-3');
    /* Mobile */
    var mobileWraps  = sec.querySelectorAll('[data-zb-m-parallax]');

    var container    = sec.querySelector('.zb-glasses-desktop');

    /* Basis-Transforms für Desktop merken (gd-2 hat translateX(-50%) vom CSS) */
    function getBaseX(el){
      return el.classList.contains('zb-gd-2') ? '-50%' : '0%';
    }

    function update(){
      var isMobile = window.innerWidth < 1024;

      if(desktopWraps.length){
        var ref   = container || sec;
        var rect  = ref.getBoundingClientRect();
        var center = rect.top + rect.height / 2 - window.innerHeight / 2;

        desktopWraps.forEach(function(w){
          var factor = parseFloat(w.getAttribute('data-zb-parallax') || '0');
          var offset = center * factor;
          var bx     = getBaseX(w);
          if(isMobile){
            w.style.transform = bx !== '0%' ? 'translateX('+bx+')' : '';
          } else {
            w.style.transform = bx !== '0%'
              ? 'translateX('+bx+') translateY('+offset+'px)'
              : 'translateY('+offset+'px)';
          }
        });
      }

      if(mobileWraps.length){
        var rect2  = sec.getBoundingClientRect();
        var center2 = rect2.top + rect2.height / 2 - window.innerHeight / 2;
        mobileWraps.forEach(function(w){
          var factor = parseFloat(w.getAttribute('data-zb-m-parallax') || '0');
          w.style.transform = isMobile ? 'translateY('+(center2*factor)+'px)' : '';
        });
      }
    }

    update();

    var ticking = false;
    window.addEventListener('scroll', function(){
      if(!ticking){
        requestAnimationFrame(function(){ update(); ticking = false; });
        ticking = true;
      }
    }, {passive: true});

    window.addEventListener('resize', function(){ update(); }, {passive: true});
  }

  /* ══ Init ════════════════════════════════════════════════════════════ */
  function init(){
    var sec = document.getElementById('zb-{{ section.id }}');
    if(!sec) return;
    buildPaws(sec);
    initParallax(sec);
  }

  document.addEventListener('shopify:section:load', function(e){
    var sec = e.target && e.target.querySelector('#zb-{{ section.id }}');
    if(!sec) sec = document.getElementById('zb-{{ section.id }}');
    if(sec){ buildPaws(sec); initParallax(sec); }
  });

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }

})();
</script>

