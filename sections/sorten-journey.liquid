  var extras   = s.zusammensetzung.filter(function(z){return z.typ==='bruehe'||z.typ==='mineral';});
  var pflPct   = pflanz.reduce(function(a,z){return a+z.pct;},0);

  /* Texte: Block-Settings haben Vorrang, sonst JS-Daten */
  var beschreibung = getText(card,'data-beschreibung',s.beschreibung);
