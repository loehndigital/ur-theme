/* ═══════════════════════════════════
   RING SVG
════════════════════════════════════ */
function buildRingSVG(ringIngredients, hoveredIdx){
  var C = 2 * Math.PI * 44;
  var total = ringIngredients.reduce(function(s,z){return s+z.pct;},0);
  var offset = 0;
  var segments = '';
  for(var i=0;i<ringIngredients.length;i++){
    var seg = ringIngredients[i];
    var segLen = (seg.pct/total)*C;
    var gap = 1.5;
    var actual = Math.max(segLen-gap,0);
    var color = getColor(seg);
    var isHov = hoveredIdx===i;
    var op = hoveredIdx===null?0.7:isHov?1:0.2;
    var sw = isHov?8:5;
    var filt = isHov?'drop-shadow(0 0 8px '+color+')':'none';
    segments += '<circle cx="50" cy="50" r="44" fill="none"'
      +' stroke="'+color+'"'
      +' stroke-width="'+sw+'"'
      +' stroke-linecap="round"'
      +' stroke-dasharray="'+actual+' '+(C-actual)+'"'
      +' stroke-dashoffset="'+(-(offset))+'"'
      +' style="opacity:'+op+';filter:'+filt+';transition:all 0.3s;cursor:pointer"'
      +' data-ring-idx="'+i+'"'
      +'/>';
    offset += segLen;
  }
  return '<svg viewBox="0 0 100 100" class="sj-rsvg" style="transform:rotate(-90deg)">'
    +'<circle cx="50" cy="50" r="44" fill="none" stroke="rgba(212,168,83,0.12)" stroke-width="5"/>'
    +segments+'</svg>';
}

