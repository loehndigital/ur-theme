/* ══════════════════════════════════
   RING HOVER
══════════════════════════════════ */
function initRingHover(container, ringIng){
  var svg = container.querySelector('.sj-rsvg');
  var tip = container.querySelector('[data-rtip]');
  if(!svg||!tip) return;

  /* Collect circle elements once — never replace the SVG again */
  var circles = {};
  svg.querySelectorAll('[data-ring-idx]').forEach(function(c){
    /* Enable smooth CSS transitions on each arc */
    c.style.transition = 'opacity .3s ease, stroke-width .3s ease, filter .3s ease';
    circles[parseInt(c.getAttribute('data-ring-idx'),10)] = c;
  });

  function highlight(idx){
    Object.keys(circles).forEach(function(key){
      var i = parseInt(key, 10);
      var c = circles[i];
      var color = getColor(ringIng[i]);
      if(idx === null){
        c.style.opacity     = '0.75';
        c.style.strokeWidth = '5';
        c.style.filter      = 'none';
      } else if(i === idx){
        c.style.opacity     = '1';
        c.style.strokeWidth = '8';
        c.style.filter      = 'drop-shadow(0 0 8px ' + color + ')';
      } else {
        c.style.opacity     = '0.18';
        c.style.strokeWidth = '5';
        c.style.filter      = 'none';
      }
    });
    if(idx !== null && ringIng[idx]){
      var s = ringIng[idx], lbl = s.label.replace(/\s*\(.*\)/,'');
      tip.textContent      = lbl + ' · ' + s.pct + '%';
      tip.style.background = getColor(s);
      tip.style.display    = 'block';
    } else {
      tip.style.display = 'none';
    }
  }

  Object.keys(circles).forEach(function(key){
    var i = parseInt(key, 10);
    var c = circles[i];
    c.addEventListener('mouseenter', function(){ highlight(i); });
    c.addEventListener('mouseleave', function(){ highlight(null); });
    c.addEventListener('click',      function(){
      highlight(i);
      setTimeout(function(){ highlight(null); }, 1400);
    });
  });
}

/* ══════════════════════════════════
   ANALYTISCH EXPAND
══════════════════════════════════ */
function initAnalytik(container){
  container.querySelectorAll('[data-atrig]').forEach(function(trig){
    trig.addEventListener('click',function(){
      var row=trig.closest('.sj-arow');
      var det=row.querySelector('[data-adet]');
      var arr=row.querySelector('[data-aarr]');
      if(det.classList.contains('sj-open')){
        det.style.maxHeight=det.scrollHeight+'px';
        requestAnimationFrame(function(){
          det.style.maxHeight='0'; det.classList.remove('sj-open');
          arr&&arr.classList.remove('sj-open');
        });
      } else {
        det.classList.add('sj-open'); arr&&arr.classList.add('sj-open');
        det.style.maxHeight=det.scrollHeight+'px';
        det.addEventListener('transitionend',function h(){
          det.style.maxHeight='none'; det.removeEventListener('transitionend',h);
        });
      }
    });
  });
}

/* ══════════════════════════════════
   ACCORDION
══════════════════════════════════ */
var openCard=null;

function closeIt(card){
  var body=card.querySelector('.sj-cbody');
  var tog=card.querySelector('.sj-ctoggle');
  var btn=card.querySelector('.sj-card-hdr');
  card.style.overflow='';          /* re-enable card clip before animating shut */
  body.style.overflow='';          /* re-enable body clip */
  body.style.maxHeight=body.scrollHeight+'px';
  requestAnimationFrame(function(){
    body.style.transition='max-height .4s ease-in-out';
    body.style.maxHeight='0';
    body.classList.remove('sj-open');
    body.setAttribute('aria-hidden','true');
    btn&&btn.setAttribute('aria-expanded','false');
    tog&&(tog.style.transform='');
  });
  openCard=null;
}

function openIt(card){
  var sorteId = card.getAttribute('data-sorte-id');
  var s = SORTEN[sorteId]; if(!s) return;

  var body=card.querySelector('.sj-cbody');
  var tog=card.querySelector('.sj-ctoggle');
  var btn=card.querySelector('.sj-card-hdr');

  /* Collapsed header befüllen */
  var nameEl=card.querySelector('[data-sorte-name]');
  var subEl =card.querySelector('[data-sorte-subname]');
  var tagsEl=card.querySelector('[data-tags-wrap]');
  var preisEl=card.querySelector('[data-preis-display]');
  if(nameEl) nameEl.textContent = getText(card,'data-name',s.name);
  if(subEl)  subEl.textContent  = getText(card,'data-subname',s.subName);
  if(tagsEl) tagsEl.innerHTML   = s.tags.map(function(t){return '<span class="sj-ctag">'+t+'</span>';}).join('');
  if(preisEl&&!preisEl.textContent.trim()) preisEl.textContent = getText(card,'data-preis',s.preis);

  /* Expanded HTML einmalig aufbauen */
  if(!body.getAttribute('data-built')){
    var pImg = card.getAttribute('data-product-image')||'';
    var gImg = card.getAttribute('data-glass-image')||'';
    body.innerHTML = buildExpanded(s, card, pImg, gImg);
    body.setAttribute('data-built','1');
    initAnalytik(body);
    var rc = body.querySelector('[data-ring-container]');
    if(rc){ var ri=s.zusammensetzung.filter(function(z){return z.typ!=='bruehe'&&z.typ!=='mineral';}); initRingHover(rc,ri); }
  }

  body.classList.add('sj-open');
  body.setAttribute('aria-hidden','false');
  btn&&btn.setAttribute('aria-expanded','true');
  tog&&(tog.style.transform='rotate(45deg)');
  body.style.transition='max-height .5s ease-in-out';
  body.style.maxHeight=body.scrollHeight+'px';
  body.addEventListener('transitionend',function h(){
    if(body.classList.contains('sj-open')){
      body.style.maxHeight='none';
      body.style.overflow='visible';   /* cbody: let shadows bleed out */
      card.style.overflow='visible';   /* .sj-card was overflow:hidden — unlock so drop-shadows escape */
    }
    body.removeEventListener('transitionend',h);
  });
  openCard=card;
}

function toggle(card){
  if(openCard===card){ closeIt(card); return; }
  var topBefore=card.getBoundingClientRect().top;
  /* Vorherige Karte sofort schließen (kein Jump) */
  if(openCard){
    var prev=openCard, pb=prev.querySelector('.sj-cbody');
    var pt=prev.querySelector('.sj-ctoggle'), ph=prev.querySelector('.sj-card-hdr');
    prev.style.overflow='';        /* reset card overflow */
    pb.style.overflow='';          /* reset body overflow */
    pb.style.transition='none'; pb.style.maxHeight='0';
    pb.classList.remove('sj-open'); pb.setAttribute('aria-hidden','true');
    ph&&ph.setAttribute('aria-expanded','false'); pt&&(pt.style.transform='');
    openCard=null;
  }
  var html=document.documentElement, prev=html.style.scrollBehavior;
  html.style.scrollBehavior='auto';
  openIt(card);
  requestAnimationFrame(function(){
    var drift=card.getBoundingClientRect().top-topBefore;
    if(Math.abs(drift)>2) window.scrollBy(0,drift);
    html.style.scrollBehavior=prev;
  });
}

/* ══════════════════════════════════
   INIT
══════════════════════════════════ */
function init(){
  var sec=document.getElementById('sj-{{ section.id }}');
  if(!sec) return;
  sec.querySelectorAll('.sj-card').forEach(function(card){
    var s=SORTEN[card.getAttribute('data-sorte-id')]; if(!s) return;
    /* Header vorab befüllen */
    var nameEl=card.querySelector('[data-sorte-name]');
    var subEl =card.querySelector('[data-sorte-subname]');
    var tagsEl=card.querySelector('[data-tags-wrap]');
    var preisEl=card.querySelector('[data-preis-display]');
    if(nameEl) nameEl.textContent = getText(card,'data-name',s.name);
    if(subEl)  subEl.textContent  = getText(card,'data-subname',s.subName);
    if(tagsEl) tagsEl.innerHTML   = s.tags.map(function(t){return '<span class="sj-ctag">'+t+'</span>';}).join('');
    if(preisEl&&!preisEl.textContent.trim()) preisEl.textContent = getText(card,'data-preis',s.preis);
    card.querySelector('.sj-card-hdr').addEventListener('click',function(){ toggle(card); });
  });
}

if(document.readyState==='loading'){
  document.addEventListener('DOMContentLoaded',init);
} else { init(); }

})();
</script>

