  'Fleischbrühe':'hsla(35,30%,42%,0.5)','Algenkalk':'hsla(165,25%,48%,0.65)'
};
var TYP_COLORS = {
  muskelfleisch:'hsl(350 35% 50%)',innereien:'hsl(340 28% 36%)',
  gemuese:'hsl(142 28% 40%)',getreide:'hsl(38 50% 50%)',
  obst:'hsl(22 55% 50%)',bruehe:'hsla(32,25%,52%,0.4)',mineral:'hsla(175,25%,46%,0.55)'
};
function getColor(seg){ return ING_COLORS[seg.label]||TYP_COLORS[seg.typ]||'#888'; }

/* ══════════════════════════════════
   EMOJIS
══════════════════════════════════ */
var TYP_EMOJIS = {
  muskelfleisch:'🥩',innereien:'❤️',gemuese:'🥦',getreide:'🌾',
  obst:'🍎',bruehe:'🫕',mineral:'🪸'
};
function getEmoji(seg){
  var lbl = seg.label.toLowerCase();
  /* Muskelfleisch – nach Tier */
  if(seg.typ === 'muskelfleisch'){
    if(lbl.includes('rind'))                          return '🐄';
    if(lbl.includes('reh')||lbl.includes('hirsch'))   return '🦌';
    if(lbl.includes('pferd'))                         return '🐴';
    if(lbl.includes('lamm'))                          return '🐑';
    if(lbl.includes('huhn')||lbl.includes('gefl'))    return '🍗';
    if(lbl.includes('ente'))                          return '🦆';
    if(lbl.includes('lachs')||lbl.includes('fisch'))  return '🐟';
  }
  /* Innereien */
  if(lbl.includes('herz'))                      return '❤️';
  if(lbl.includes('lunge')||lbl.includes('luftröhre')) return '💨';
  if(lbl.includes('leber'))                     return '🔴';
  if(lbl.includes('mägen')||lbl.includes('magen')) return '🫙';
  if(lbl.includes('hals'))                      return '🦴';
  /* Gemüse */
  if(lbl.includes('karotte')||lbl.includes('karotten')) return '🥕';
  if(lbl.includes('süßkartoffel'))              return '🍠';
  if(lbl.includes('kartoffeln'))                return '🥔';
  if(lbl.includes('kürbis'))                    return '🎃';
  if(lbl.includes('zucchini'))                  return '🥒';
  if(lbl.includes('rote beete'))                return '🫑';
  /* Obst */
  if(lbl.includes('apfel'))                     return '🍎';
  /* Getreide */
  if(lbl.includes('haferkleie'))                return '🌾';
  if(lbl.includes('quinoa')||lbl.includes('amaranth')||lbl.includes('hirse')) return '🌾';
  /* Basis */
  if(lbl.includes('fleischbrühe'))              return '🫕';
  if(lbl.includes('algenkalk'))                 return '🪸';
  return TYP_EMOJIS[seg.typ] || '🥩';
}

/* ══════════════════════════════════
   HILFSFUNKTION: Block-Text oder Fallback
══════════════════════════════════ */
function getText(card, attr, fallback){
  var v = card.getAttribute(attr)||'';
  return v.trim() ? v : (fallback||'');
}
function getBenefits(card, fallback){
  var raw = (card.getAttribute('data-benefits')||'').trim();
  if(raw){ return raw.split('\n').map(function(l){return l.trim();}).filter(Boolean).slice(0,5); }
  return fallback||[];
}

/* ══════════════════════════════════
   RING SVG
══════════════════════════════════ */
function buildRingSVG(ringIng, hov){
  var C = 2*Math.PI*44, tot = ringIng.reduce(function(s,z){return s+z.pct;},0);
  var offset=0, segs='';
  for(var i=0;i<ringIng.length;i++){
    var seg=ringIng[i], len=(seg.pct/tot)*C, act=Math.max(len-1.5,0);
    var c=getColor(seg), isH=(hov===i);
    var op = hov===null?0.75:isH?1:0.18;
    var sw = isH?8:5, flt=isH?'drop-shadow(0 0 8px '+c+')':'none';
    segs+='<circle cx="50" cy="50" r="44" fill="none" stroke="'+c+'" stroke-width="'+sw+'"'
      +' stroke-linecap="round" stroke-dasharray="'+act+' '+(C-act)+'"'
      +' stroke-dashoffset="'+(-(offset))+'" data-ring-idx="'+i+'"'
      +' style="opacity:'+op+';filter:'+flt+';transition:all .3s;cursor:pointer"/>';
    offset+=len;
  }
  return '<svg viewBox="0 0 100 100" class="sj-rsvg" style="transform:rotate(-90deg)">'
    +'<circle cx="50" cy="50" r="44" fill="none" stroke="rgba(44,26,14,0.1)" stroke-width="5"/>'
    +segs+'</svg>';
}

