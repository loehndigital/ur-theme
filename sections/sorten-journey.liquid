/* ═══════════════════════════════════
   RING HOVER
════════════════════════════════════ */
function initRingHover(container, ringIngredients){
  var svg = container.querySelector('[data-ring-idx]') ? container.querySelector('.sj-rsvg') : null;
  var tip = container.querySelector('[data-rtip]');
  if(!svg||!tip) return;

  function redraw(idx){
    var newSVG = buildRingSVG(ringIngredients, idx);
    var tmp = document.createElement('div');
    tmp.innerHTML = newSVG;
    var newEl = tmp.firstChild;
    svg.parentNode.replaceChild(newEl, svg);
    svg = newEl;
    attachHandlers();
    if(idx!==null && ringIngredients[idx]){
      var seg = ringIngredients[idx];
      var lbl = seg.label.replace(/\s*\(.*\)/,'');
      tip.textContent = lbl+' · '+seg.pct+'%';
      tip.style.background = getColor(seg);
      tip.style.display = 'block';
    } else {
      tip.style.display = 'none';
    }
  }

  function attachHandlers(){
    var circles = svg.querySelectorAll('[data-ring-idx]');
    circles.forEach(function(c){
      var i = parseInt(c.getAttribute('data-ring-idx'),10);
      c.addEventListener('mouseenter',function(){redraw(i);});
      c.addEventListener('mouseleave',function(){redraw(null);});
      c.addEventListener('click',function(){redraw(i);setTimeout(function(){redraw(null);},1200);});
    });
  }

  attachHandlers();
}

/* ═══════════════════════════════════
   ANALYTISCH ROWS
════════════════════════════════════ */
function initAnalytikRows(container){
  var trigs = container.querySelectorAll('[data-atrig]');
  trigs.forEach(function(trig){
    trig.addEventListener('click',function(){
      var row = trig.closest('.sj-arow');
      var det = row.querySelector('[data-adet]');
      var arr = row.querySelector('[data-aarr]');
      var isOpen = det.classList.contains('sj-open');
      if(isOpen){
        det.style.maxHeight = det.scrollHeight+'px';
        requestAnimationFrame(function(){
          det.style.maxHeight = '0';
          det.classList.remove('sj-open');
          arr && arr.classList.remove('sj-open');
        });
      } else {
        det.classList.add('sj-open');
        arr && arr.classList.add('sj-open');
        det.style.maxHeight = det.scrollHeight+'px';
        det.addEventListener('transitionend',function onEnd(){
          det.style.maxHeight = 'none';
          det.removeEventListener('transitionend',onEnd);
        });
      }
    });
  });
}

/* ═══════════════════════════════════
   ACCORDION
════════════════════════════════════ */
var currentOpen = null;

function closeCard(card){
  var body = card.querySelector('.sj-cbody');
  var btn = card.querySelector('.sj-card-hdr');
  var tog = card.querySelector('.sj-ctoggle');
  body.style.maxHeight = body.scrollHeight+'px';
  requestAnimationFrame(function(){
    body.style.maxHeight = '0';
    body.classList.remove('sj-open');
    btn && btn.setAttribute('aria-expanded','false');
    tog && (tog.style.transform = '');
    body.setAttribute('aria-hidden','true');
  });
  currentOpen = null;
}

function openCard(card, instant){
  var sorteId = card.getAttribute('data-sorte-id');
  var s = SORTEN[sorteId];
  if(!s) return;

  var productImg = card.getAttribute('data-product-image') || '';
  var glassImg = card.getAttribute('data-glass-image') || '';
  var preis = card.getAttribute('data-preis') || s.preis;

  var body = card.querySelector('.sj-cbody');
  var btn = card.querySelector('.sj-card-hdr');
  var tog = card.querySelector('.sj-ctoggle');

  /* Populate header data */
  var nameEl = card.querySelector('[data-sorte-name]');
  var subEl = card.querySelector('[data-sorte-subname]');
  var tagsEl = card.querySelector('[data-tags-wrap]');
  var preisEl = card.querySelector('[data-preis-display]');
  if(nameEl) nameEl.textContent = s.name;
  if(subEl) subEl.textContent = s.subName;
  if(tagsEl) tagsEl.innerHTML = s.tags.map(function(t){return '<span class="sj-ctag">'+t+'</span>';}).join('');
  if(preisEl) preisEl.textContent = preis || s.preis;

  /* Build expanded if empty */
  if(!body.getAttribute('data-built')){
    body.innerHTML = buildExpandedHTML(s, productImg, glassImg);
    body.setAttribute('data-built','1');
    initAnalytikRows(body);
    var ringContainer = body.querySelector('[data-ring-container]');
    if(ringContainer){
      var ringIng = s.zusammensetzung.filter(function(z){return z.typ!=='bruehe'&&z.typ!=='mineral';});
      initRingHover(ringContainer, ringIng);
    }
  }

  body.classList.add('sj-open');
  btn && btn.setAttribute('aria-expanded','true');
  tog && (tog.style.transform = 'rotate(45deg)');
  body.setAttribute('aria-hidden','false');

  body.style.transition = instant?'none':'max-height 0.5s ease-in-out';
  body.style.maxHeight = body.scrollHeight+'px';
  body.addEventListener('transitionend', function onEnd(){
    if(body.classList.contains('sj-open')) body.style.maxHeight = 'none';
    body.removeEventListener('transitionend', onEnd);
  });

  currentOpen = card;
}

function handleToggle(card){
  if(currentOpen === card){
    closeCard(card);
    return;
  }

  var clickedTop = card.getBoundingClientRect().top;

  if(currentOpen){
    /* Instant close to avoid jump */
    var prevBody = currentOpen.querySelector('.sj-cbody');
    var prevBtn = currentOpen.querySelector('.sj-card-hdr');
    var prevTog = currentOpen.querySelector('.sj-ctoggle');
    prevBody.style.transition = 'none';
    prevBody.style.maxHeight = '0';
    prevBody.classList.remove('sj-open');
    prevBtn && prevBtn.setAttribute('aria-expanded','false');
    prevTog && (prevTog.style.transform = '');
    prevBody.setAttribute('aria-hidden','true');
    currentOpen = null;
  }

  /* Scroll compensation */
  var html = document.documentElement;
  var prevBehavior = html.style.scrollBehavior;
  html.style.scrollBehavior = 'auto';

  openCard(card, false);

  requestAnimationFrame(function(){
    var newTop = card.getBoundingClientRect().top;
    var drift = newTop - clickedTop;
    if(Math.abs(drift)>2) window.scrollBy(0, drift);
    html.style.scrollBehavior = prevBehavior;
  });
}

/* ═══════════════════════════════════
   INIT
════════════════════════════════════ */
function init(){
  var section = document.getElementById('sj-{{ section.id }}');
  if(!section) return;

  var cards = section.querySelectorAll('.sj-card');
  cards.forEach(function(card){
    var sorteId = card.getAttribute('data-sorte-id');
    var s = SORTEN[sorteId];
    if(!s) return;

    /* Pre-fill collapsed header */
    var nameEl = card.querySelector('[data-sorte-name]');
    var subEl = card.querySelector('[data-sorte-subname]');
    var tagsEl = card.querySelector('[data-tags-wrap]');
    var preisEl = card.querySelector('[data-preis-display]');
    if(nameEl) nameEl.textContent = s.name;
    if(subEl) subEl.textContent = s.subName;
    if(tagsEl) tagsEl.innerHTML = s.tags.map(function(t){return '<span class="sj-ctag">'+t+'</span>';}).join('');
    if(preisEl && !preisEl.textContent.trim()) preisEl.textContent = s.preis;

    var btn = card.querySelector('.sj-card-hdr');
    if(btn){
      btn.addEventListener('click',function(){ handleToggle(card); });
    }
  });
}

if(document.readyState==='loading'){
  document.addEventListener('DOMContentLoaded',init);
} else {
  init();
}

})();
</script>

