  var benefits     = getBenefits(card, s.benefits);
  var katDot = s.kategorie==='rot'?'● Rotes Fleisch':s.kategorie==='hell'?'● Helles Fleisch':'● Fisch';

  /* Orbit */
  var orbitHTML='';
  for(var bi=0;bi<benefits.length;bi++){
    var ang=(-90+(bi*360)/benefits.length)*(Math.PI/180);
    var x=50+46*Math.cos(ang), y=50+46*Math.sin(ang);
    /* Labels nach AUSSEN vom Bildzentrum – ab 1280px via CSS eingeblendet */
    var lL=x>55?'110%':x<45?'auto':'50%', lR=x<45?'110%':'auto';
    var lT=(x>=45&&x<=55)?(y<50?'auto':'110%'):'50%';
