{%- comment -%}
  Uncle Rusty's – Sorten Journey Accordion
  Platzierung: sections/sorten-journey.liquid
{%- endcomment -%}

<style>
#sj-{{ section.id }} {
  --sj-amber: {{ section.settings.amber_color | default: '#d4a853' }};
  padding: 64px 0;
  max-width: 1280px;
  margin: 0 auto;
}
@media(min-width:768px){#sj-{{ section.id }}{padding:96px 0}}
@media(min-width:1024px){#sj-{{ section.id }}{padding:128px 0}}

/* Glass Card */
.sj-glass{background:rgba(34,27,20,.7);border:1px solid rgba(212,168,83,.08);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px)}

/* Hero */
.sj-hero{position:relative;overflow:hidden;border-radius:0;margin:0 0 40px}
@media(min-width:768px){.sj-hero{border-radius:16px;margin:0 44px 56px}}
.sj-hero-img{width:100%;object-fit:cover;aspect-ratio:16/10;display:block}
@media(min-width:768px){.sj-hero-img{aspect-ratio:21/9}}
.sj-hero-or{position:absolute;inset:0;pointer-events:none;background:linear-gradient(to right,rgba(25,19,16,.92) 0%,rgba(25,19,16,.5) 40%,transparent 70%)}
.sj-hero-ob{position:absolute;inset:0;pointer-events:none;background:linear-gradient(to top,#171210 0%,transparent 30%)}
.sj-hero-content{position:absolute;inset:0;display:flex;align-items:center;padding:0 24px}
@media(min-width:768px){.sj-hero-content{padding:0 40px}}
@media(min-width:1024px){.sj-hero-content{padding:0 56px}}
.sj-badge{display:inline-block;padding:4px 12px;border-radius:999px;background:rgba(212,168,83,.1);border:1px solid rgba(212,168,83,.2);color:#d4a853;font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;margin-bottom:12px}
.sj-h2{font-size:26px;font-weight:700;line-height:1.08;color:#f0e4cc;margin:0 0 12px}
@media(min-width:768px){.sj-h2{font-size:44px;margin-bottom:20px}}
@media(min-width:1024px){.sj-h2{font-size:52px}}
.sj-h2 em{font-style:italic;color:#d4a853}
.sj-hero-p{color:#c4a87a;font-size:13px;line-height:1.7;max-width:448px;display:none}
@media(min-width:640px){.sj-hero-p{display:block}}
@media(min-width:768px){.sj-hero-p{font-size:15px}}
.sj-mobile-sub{display:block;color:#c4a87a;font-size:14px;line-height:1.7;padding:0 20px;margin-bottom:32px}
@media(min-width:640px){.sj-mobile-sub{display:none}}

/* Inner */
.sj-inner{padding:0 20px}
@media(min-width:768px){.sj-inner{padding:0 44px}}

/* Wochen */
.sj-wochen{padding:16px;border-radius:12px;display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:16px;margin-bottom:40px}
@media(min-width:768px){.sj-wochen{padding:24px;gap:20px;margin-bottom:56px}}
@media(min-width:1024px){.sj-wochen{padding:28px;gap:32px}}
.sj-wi{text-align:center}
.sj-wi-dots{display:flex;justify-content:center;gap:6px;margin-bottom:8px}
.sj-wi-dot{width:10px;height:10px;border-radius:50%}
.sj-wi-lbl{color:#f0e4cc;font-size:12px;font-weight:500}
.sj-wi-sub{color:#7a6448;font-size:11px;margin-top:2px}
.sj-wi-tot{font-size:24px;font-weight:700;color:#d4a853}
.sj-wi-tot-l{font-size:11px;font-weight:500;color:#d4a853;margin-top:2px}
.sj-wi-tot-s{font-size:10px;color:rgba(212,168,83,.5)}
.sj-divl{display:none;width:1px;height:48px;background:linear-gradient(to bottom,transparent,rgba(255,220,140,.1),transparent)}
@media(min-width:768px){.sj-divl{display:block}}

/* Category Divider */
.sj-catdiv{display:flex;align-items:center;gap:20px;margin:40px 0}
.sj-catline{flex:1;height:1px}
.sj-catinner{display:flex;align-items:center;gap:10px}
.sj-catdot{width:6px;height:6px;border-radius:50%}
.sj-cattxt{font-size:11px;letter-spacing:.05em;font-weight:500}

/* Card */
.sj-card{border-radius:16px;margin-bottom:12px;overflow:hidden}
.sj-card-hdr{width:100%;padding:16px 20px;display:flex;align-items:center;gap:12px;text-align:left;background:transparent;border:none;cursor:pointer;transition:background .3s;color:inherit}
@media(min-width:768px){.sj-card-hdr{padding:20px 24px;gap:16px}}
.sj-card-hdr:hover{background:rgba(42,34,24,.3)}
.sj-card-hdr:focus{outline:none}
.sj-card-img{width:56px;height:56px;border-radius:12px;object-fit:cover;flex-shrink:0;box-shadow:0 4px 12px rgba(0,0,0,.4)}
@media(min-width:1024px){.sj-card-img{width:64px;height:64px}}
.sj-cinfo{flex:1;min-width:0}
.sj-ckat{color:#7a6448;font-size:10px;letter-spacing:.05em;margin-bottom:2px}
@media(min-width:768px){.sj-ckat{font-size:11px}}
.sj-cname{color:#f0e4cc;font-size:17px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
@media(min-width:768px){.sj-cname{font-size:18px}}
@media(min-width:1024px){.sj-cname{font-size:20px}}
.sj-csub{color:#7a6448;font-size:13px;font-weight:400}
.sj-ctags{display:none;gap:8px}
@media(min-width:768px){.sj-ctags{display:flex}}
.sj-ctag{padding:4px 10px;border-radius:999px;font-size:11px;border:1px solid rgba(212,168,83,.12);color:#7a6448}
.sj-cpreis{color:#d4a853;font-size:15px;font-weight:600;flex-shrink:0}
@media(min-width:768px){.sj-cpreis{font-size:14px}}
.sj-ctoggle{color:rgba(212,168,83,.7);font-size:20px;line-height:1;flex-shrink:0;transition:transform .3s;font-weight:300;background:none;border:none;cursor:pointer}

/* Card Body */
.sj-cbody{overflow:hidden;max-height:0;transition:max-height .5s ease-in-out}
.sj-cbody.sj-open{border-top:1px solid rgba(212,168,83,.08)}

/* Expanded: Hero */
.sj-xhero{position:relative;overflow:hidden}
.sj-xhero-bg{position:absolute;inset:0;background:linear-gradient(135deg,rgba(42,34,24,.4),rgba(25,19,16,.8))}
.sj-xgrid{position:relative;z-index:1;display:grid;grid-template-columns:1fr}
@media(min-width:768px){.sj-xgrid{grid-template-columns:1fr 1fr}}
.sj-ximg-wrap{position:relative;display:flex;align-items:center;justify-content:center;padding:32px 0}
@media(min-width:768px){.sj-ximg-wrap{padding:48px 0}}
@media(min-width:1024px){.sj-ximg-wrap{padding:64px 0}}
.sj-xglow{position:absolute;width:192px;height:192px;border-radius:50%;filter:blur(80px);opacity:.2;background:#d4a853}
@media(min-width:768px){.sj-xglow{width:288px;height:288px}}
.sj-xpimg{position:relative;z-index:2;width:112px;height:112px;object-fit:contain;filter:drop-shadow(0 25px 50px rgba(0,0,0,.5))}
@media(min-width:768px){.sj-xpimg{width:160px;height:160px}}
@media(min-width:1024px){.sj-xpimg{width:224px;height:224px}}
.sj-orbit{position:absolute;z-index:3;width:160px;height:160px;pointer-events:none}
@media(min-width:768px){.sj-orbit{width:224px;height:224px}}
@media(min-width:1024px){.sj-orbit{width:288px;height:288px}}
.sj-orbit-dot{position:absolute;display:none}
@media(min-width:768px){.sj-orbit-dot{display:block}}
.sj-orbit-star{width:20px;height:20px;border-radius:50%;background:#d4a853;box-shadow:0 0 12px rgba(212,168,83,.5),0 0 24px rgba(212,168,83,.2);display:flex;align-items:center;justify-content:center;font-size:9px;color:#171210}
@media(min-width:768px){.sj-orbit-star{width:24px;height:24px;font-size:10px}}
.sj-orbit-lbl{position:absolute;white-space:nowrap;padding:4px 10px;border-radius:999px;font-size:9px;font-weight:500;background:rgba(42,34,24,.8);border:1px solid rgba(212,168,83,.15);color:#f0e4cc;backdrop-filter:blur(4px)}
@media(min-width:768px){.sj-orbit-lbl{font-size:10px}}
.sj-xdesc{display:flex;flex-direction:column;justify-content:center;padding:24px 20px}
@media(min-width:768px){.sj-xdesc{padding:48px 40px}}
.sj-xkat{color:#d4a853;font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;margin-bottom:8px}
@media(min-width:768px){.sj-xkat{font-size:11px;margin-bottom:12px}}
.sj-xh3{color:#f0e4cc;font-size:28px;font-weight:700;margin:0 0 4px}
@media(min-width:768px){.sj-xh3{font-size:40px}}
@media(min-width:1024px){.sj-xh3{font-size:48px}}
.sj-xsubname{color:rgba(212,168,83,.8);font-size:16px;margin-bottom:16px}
@media(min-width:768px){.sj-xsubname{font-size:20px;margin-bottom:20px}}
.sj-xbesch{color:#c4a87a;font-size:13px;line-height:1.7;margin-bottom:16px;max-width:448px}
@media(min-width:768px){.sj-xbesch{font-size:15px;margin-bottom:24px}}
.sj-badges{display:flex;gap:12px}
.sj-nbadge{padding:10px 16px;border-radius:12px;background:rgba(212,168,83,.06);border:1px solid rgba(212,168,83,.12)}
.sj-cbadge{padding:10px 16px;border-radius:12px;background:rgba(52,168,52,.06);border:1px solid rgba(52,168,52,.12)}
.sj-nval{color:#d4a853;font-size:18px;font-weight:700}
.sj-cval{color:#5db85d;font-size:18px;font-weight:700}
.sj-blbl{color:#7a6448;font-size:11px;margin-left:8px}

/* Zusammensetzung */
.sj-zsm{padding:24px 16px;border-top:1px solid rgba(212,168,83,.08)}
@media(min-width:768px){.sj-zsm{padding:32px}}
.sj-zsm-ttl{text-align:center;margin-bottom:16px}
@media(min-width:768px){.sj-zsm-ttl{margin-bottom:24px}}
.sj-zsm-h4{color:#f0e4cc;font-size:22px;font-weight:700}
@media(min-width:768px){.sj-zsm-h4{font-size:28px}}
@media(min-width:1024px){.sj-zsm-h4{font-size:32px}}
.sj-zsm-hint{color:#7a6448;font-size:11px;margin-top:4px}
.sj-zsm-layout{display:flex;flex-direction:column;align-items:center;gap:16px}
@media(min-width:768px){.sj-zsm-layout{flex-direction:row;gap:24px}}
.sj-fleisch-box{flex:1;width:100%;order:2;border-radius:16px;padding:16px;background:rgba(180,80,70,.04);border:1px solid rgba(180,80,70,.1)}
@media(min-width:768px){.sj-fleisch-box{order:1}}
.sj-pflanz-box{flex:1;width:100%;order:3}
.sj-pflanz-inner{border-radius:16px;padding:16px;background:rgba(52,168,52,.04);border:1px solid rgba(52,168,52,.1);margin-bottom:12px}
.sj-extra-inner{border-radius:16px;padding:16px;background:rgba(42,34,24,.25);border:1px solid rgba(212,168,83,.08)}
.sj-box-hdr{display:flex;align-items:center;gap:8px;margin-bottom:8px;padding:0 4px}
.sj-box-lbl{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase}
.sj-irow{display:flex;align-items:center;gap:8px;padding:6px 10px;border-radius:8px;transition:background .3s;cursor:default}
.sj-irow:hover{background:rgba(212,168,83,.06)}
.sj-iicon{width:28px;height:28px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:12px}
.sj-iname{color:#f0e4cc;font-size:12px;font-weight:600;line-height:1.2}
.sj-ihigh{color:rgba(196,168,122,.4);font-size:9px}
.sj-ipct{color:#d4a853;font-size:14px;font-weight:700;margin-left:auto;flex-shrink:0}

/* Ring */
.sj-ring-wrap{position:relative;order:1;flex-shrink:0;width:176px;height:176px;display:flex;align-items:center;justify-content:center}
@media(min-width:768px){.sj-ring-wrap{order:2;width:224px;height:224px}}
@media(min-width:1024px){.sj-ring-wrap{width:288px;height:288px}}
.sj-rglow{position:absolute;width:100%;height:100%;border-radius:50%;filter:blur(50px);opacity:.1;background:#d4a853}
.sj-rsvg{position:absolute;inset:0;width:100%;height:100%}
.sj-rglass{position:relative;z-index:2;width:96px;height:auto;filter:drop-shadow(0 12px 35px rgba(0,0,0,.4))}
@media(min-width:768px){.sj-rglass{width:128px}}
@media(min-width:1024px){.sj-rglass{width:176px}}
.sj-rtip{position:absolute;bottom:-8px;left:50%;transform:translateX(-50%);z-index:10;padding:4px 12px;border-radius:999px;font-size:11px;font-weight:700;white-space:nowrap;color:white;display:none;pointer-events:none}

/* Deklaration */
.sj-dekl{margin:0 16px 24px;border-radius:16px;overflow:hidden;background:linear-gradient(135deg,rgba(42,34,24,.6),rgba(34,27,20,.2));border:1px solid rgba(212,168,83,.18);position:relative}
@media(min-width:768px){.sj-dekl{margin:0 24px 40px}}
@media(min-width:1024px){.sj-dekl{margin:0 40px 40px}}
.sj-dekl-bar{position:absolute;top:0;left:0;width:6px;height:100%;background:linear-gradient(to bottom,#d4a853,rgba(212,168,83,.4))}
.sj-dekl-body{padding:16px 24px 16px 20px}
@media(min-width:768px){.sj-dekl-body{padding:24px 32px 24px 28px}}
@media(min-width:1024px){.sj-dekl-body{padding:32px 40px 32px 36px}}
.sj-dekl-lbl{color:#d4a853;font-size:10px;font-weight:700;letter-spacing:.25em;text-transform:uppercase;margin-bottom:8px}
.sj-dekl-txt{color:#f0e4cc;font-size:13px;line-height:1.8;font-weight:500}
@media(min-width:768px){.sj-dekl-txt{font-size:14px;line-height:1.9}}

/* Bottom grid */
.sj-botgrid{display:grid;grid-template-columns:1fr;border-top:1px solid rgba(212,168,83,.08)}
@media(min-width:768px){.sj-botgrid{grid-template-columns:1fr 1fr}}
.sj-anal{padding:24px 16px;border-bottom:1px solid rgba(212,168,83,.08)}
@media(min-width:768px){.sj-anal{padding:40px;border-bottom:none;border-right:1px solid rgba(212,168,83,.08)}}
.sj-bens{padding:24px 16px}
@media(min-width:768px){.sj-bens{padding:40px}}
.sj-sec-h4{color:#f0e4cc;font-size:18px;font-weight:700;margin-bottom:4px}
@media(min-width:768px){.sj-sec-h4{font-size:22px}}
.sj-sec-hint{color:#7a6448;font-size:11px;margin-bottom:16px}
@media(min-width:768px){.sj-sec-hint{margin-bottom:24px}}
.sj-sec-hint-a{color:#d4a853;font-weight:600}

/* Analytisch Row */
.sj-arow{border-bottom:1px solid rgba(212,168,83,.08)}
.sj-arow:last-child{border-bottom:none}
.sj-atrig{width:100%;display:flex;align-items:center;justify-content:space-between;padding:12px 4px;background:none;border:none;cursor:pointer;text-align:left;border-radius:4px;transition:background .2s;color:inherit}
.sj-atrig:hover{background:rgba(42,34,24,.2)}
.sj-albl{color:#c4a87a;font-size:13px}
.sj-aright{display:flex;align-items:center;gap:10px}
.sj-aval{color:#f0e4cc;font-size:13px;font-weight:500}
.sj-aarr{color:rgba(122,100,72,.4);font-size:9px;transition:transform .3s;display:inline-block}
.sj-aarr.sj-open{transform:rotate(180deg)}
.sj-adet{overflow:hidden;max-height:0;opacity:0;transition:max-height .35s cubic-bezier(.4,0,.2,1),opacity .25s ease}
.sj-adet.sj-open{opacity:1}
.sj-atxt{color:#7a6448;font-size:12px;line-height:1.6;padding-bottom:14px;padding-left:4px}
.sj-nosynth{color:rgba(122,100,72,.5);font-size:10px;margin-top:16px;font-style:italic}

/* Benefits */
.sj-bengrid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:24px}
@media(min-width:768px){.sj-bengrid{margin-bottom:32px}}
.sj-benitem{display:flex;align-items:flex-start;gap:8px;padding:10px 12px;border-radius:12px;background:rgba(212,168,83,.04);border:1px solid rgba(212,168,83,.1)}
.sj-benstar{color:#d4a853;font-size:12px;margin-top:1px}
.sj-bentxt{color:#f0e4cc;font-size:12px;font-weight:500;line-height:1.4}
.sj-wusstest{border-radius:16px;padding:20px;margin-bottom:16px;background:linear-gradient(135deg,rgba(212,168,83,.06),rgba(212,168,83,.02));border:1px solid rgba(212,168,83,.12)}
.sj-wuss-ttl{color:#d4a853;font-size:14px;font-weight:700;margin-bottom:8px}
.sj-wuss-txt{color:#c4a87a;font-size:13px;line-height:1.6}
.sj-empt{padding:16px;border-radius:12px;background:rgba(52,168,52,.06);border:1px solid rgba(52,168,52,.12)}
.sj-empt-txt{color:#5db85d;font-size:12px;font-weight:700}

/* Placeholder image */
.sj-img-ph{background:rgba(42,34,24,.6);display:flex;align-items:center;justify-content:center;color:#7a6448;font-size:24px}
</style>

<section id="sj-{{ section.id }}">

  {%- comment -%} Hero Banner {%- endcomment -%}
  <div class="sj-hero">
    {%- if section.settings.hero_image != blank -%}
      <img
        src="{{ section.settings.hero_image | image_url: width: 1600 }}"
        alt="{{ section.settings.hero_image.alt | escape | default: 'Alle Sorten im Überblick' }}"
        class="sj-hero-img"
        loading="lazy"
        width="{{ section.settings.hero_image.width }}"
        height="{{ section.settings.hero_image.height }}"
      >
    {%- else -%}
      <div class="sj-hero-img sj-img-ph" style="min-height:300px">🐕</div>
    {%- endif -%}
    <div class="sj-hero-or"></div>
    <div class="sj-hero-ob"></div>
    <div class="sj-hero-content">
      <div style="max-width:512px">
        <span class="sj-badge">{{ section.settings.badge_text | default: '✦ 7 SORTEN' }}</span>
        <h2 class="sj-h2">
          {{ section.settings.headline | default: 'Die perfekte Woche' }}<br>
          <em>{{ section.settings.headline_highlight | default: 'für deinen Hund.' }}</em>
        </h2>
        <p class="sj-hero-p">{{ section.settings.subtext | default: '7 Menüs. Jedes für sich komplett. Zusammen die Grundlage für eine natürliche, abwechslungsreiche Ernährung.' }}</p>
      </div>
    </div>
  </div>

  <p class="sj-mobile-sub">{{ section.settings.subtext | default: '7 Menüs. Jedes für sich komplett. Zusammen die Grundlage für eine natürliche, abwechslungsreiche Ernährung.' }}</p>

  <div class="sj-inner">

    {%- comment -%} Wochen Banner {%- endcomment -%}
    <div class="sj-wochen sj-glass">
      <div class="sj-wi">
        <div class="sj-wi-dots">
          <div class="sj-wi-dot" style="background:hsl(350 35% 52%)"></div>
          <div class="sj-wi-dot" style="background:hsl(350 35% 52%)"></div>
          <div class="sj-wi-dot" style="background:hsl(350 35% 52%)"></div>
        </div>
        <p class="sj-wi-lbl">3× Rotes Fleisch</p>
        <p class="sj-wi-sub">Rind · Wild · Pferd · Lamm</p>
      </div>
      <div class="sj-divl"></div>
      <div class="sj-wi">
        <div class="sj-wi-dots">
          <div class="sj-wi-dot" style="background:hsl(38 55% 55%)"></div>
          <div class="sj-wi-dot" style="background:hsl(38 55% 55%)"></div>
          <div class="sj-wi-dot" style="background:hsl(38 55% 55%)"></div>
        </div>
        <p class="sj-wi-lbl">3× Helles Fleisch</p>
        <p class="sj-wi-sub">Geflügel · Ente</p>
      </div>
      <div class="sj-divl"></div>
      <div class="sj-wi">
        <div class="sj-wi-dots">
          <div class="sj-wi-dot" style="background:hsl(207 45% 58%)"></div>
        </div>
        <p class="sj-wi-lbl">1× Fisch</p>
        <p class="sj-wi-sub">Lachs · Omega 3</p>
      </div>
      <div class="sj-divl"></div>
      <div class="sj-wi" style="text-align:center">
        <p class="sj-wi-tot">= 7</p>
        <p class="sj-wi-tot-l">Perfekte Woche</p>
        <p class="sj-wi-tot-s">Unsere Empfehlung</p>
      </div>
    </div>

    {%- comment -%} Rotes Fleisch {%- endcomment -%}
    {%- assign has_rot = false -%}
    {%- for block in section.blocks -%}{%- if block.settings.kategorie == 'rot' -%}{%- assign has_rot = true -%}{%- break -%}{%- endif -%}{%- endfor -%}
    {%- if has_rot -%}
    <div class="sj-catdiv">
      <div class="sj-catline" style="background:linear-gradient(to right,transparent,rgba(180,80,70,.3),transparent)"></div>
      <div class="sj-catinner">
        <div class="sj-catdot" style="background:hsl(350 35% 52%)"></div>
        <span class="sj-cattxt" style="color:hsl(350 35% 52%)">Rotes Fleisch · 3× pro Woche</span>
      </div>
      <div class="sj-catline" style="background:linear-gradient(to right,transparent,rgba(180,80,70,.3),transparent)"></div>
    </div>
