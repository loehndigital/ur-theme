{%- comment -%}
  Uncle Rusty's – Basis Komplett
  Platzierung: sections/basis-komplett.liquid
{%- endcomment -%}

{%- assign ac  = section.settings.accent_color | default: '#c4622d' -%}
{%- assign ar  = ac | color_extract: 'red'   -%}
{%- assign ag  = ac | color_extract: 'green' -%}
{%- assign ab  = ac | color_extract: 'blue'  -%}

{%- assign pad_mobile  = section.settings.padding_mobile  | default: 60  -%}
{%- assign pad_tablet  = section.settings.padding_tablet  | default: 100 -%}
{%- assign pad_desktop = section.settings.padding_desktop | default: 120 -%}

{%- assign bg_style  = section.settings.bg_style | default: 'paw_dark' -%}
{%- assign bk_is_dark = false -%}
{%- if bg_style == 'paw_dark' or bg_style == 'plain_dark' -%}
  {%- assign bk_is_dark = true -%}
{%- endif -%}

<style>
/* ╔══════════════════════════════════════╗
   ║  UNCLE RUSTY'S – BASIS KOMPLETT     ║
   ╚══════════════════════════════════════╝ */

#bk-{{ section.id }} {
  --bk-accent: {{ ac }};
  --bk-blue:   #5ca3cb;
  --bk-green:  #5a9e5a;
  --bk-red:    #b84028;

  {%- if bk_is_dark -%}
  --bk-text:   #f5ede0;
  --bk-text2:  #d4b896;
  --bk-dim:    #9a7c5a;
  --bk-muted:  rgba(245,237,224,0.38);
  --bk-card:   rgba(245,237,224,0.06);
  --bk-border: rgba(245,237,224,0.10);
  --bk-row:    rgba(245,237,224,0.05);
  {%- else -%}
  --bk-text:   #2c1a0e;
  --bk-text2:  #7a5c3a;
  --bk-dim:    #9a7c5a;
  --bk-muted:  rgba(60,35,15,0.4);
  --bk-card:   rgba(60,35,15,0.05);
  --bk-border: rgba(60,35,15,0.12);
  --bk-row:    rgba(60,35,15,0.04);
  {%- endif -%}

  {%- if bg_style == 'transparent' -%}
  background: transparent;
  {%- elsif bg_style == 'plain_dark' or bg_style == 'paw_dark' -%}
  background-color: #1a0e05;
  {%- else -%}
  background-color: #EBE6D9;
  {%- endif -%}

  position: relative;
  overflow: hidden;
  padding: {{ pad_mobile }}px 20px;
  font-family: inherit;
}
@media(min-width:768px)  { #bk-{{ section.id }} { padding: {{ pad_tablet }}px 28px  } }
@media(min-width:1024px) { #bk-{{ section.id }} { padding: {{ pad_desktop }}px 48px } }

/* ══ Paw-Pattern ════════════════════════ */
#bk-{{ section.id }} .bk-paws-ctn {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
}

/* ══ Inner ══════════════════════════════ */
#bk-{{ section.id }} .bk-inner {
  position: relative;
  z-index: 1;
  max-width: 1180px;
  margin: 0 auto;
}

/* ══ Badge ══════════════════════════════ */
#bk-{{ section.id }} .bk-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 14px;
  border-radius: 999px;
  background: rgba({{ ar }},{{ ag }},{{ ab }},0.10);
  border: 1px solid rgba({{ ar }},{{ ag }},{{ ab }},0.25);
  color: var(--bk-accent);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .18em;
  text-transform: uppercase;
  margin-bottom: 12px;
}

/* ══ Hero Grid ══════════════════════════ */
#bk-{{ section.id }} .bk-hero {
  display: grid;
  grid-template-columns: 1fr;
  align-items: center;
  margin-bottom: 20px;
}
@media(min-width:1024px) {
  #bk-{{ section.id }} .bk-hero {
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    margin-bottom: 28px;
  }
}

/* ══ Headline ═══════════════════════════ */
#bk-{{ section.id }} .bk-headline {
  font-size: clamp(26px,4.5vw,54px);
  font-weight: 700;
  line-height: 1.06;
  color: var(--bk-text);
  margin: 0 0 16px;
}
#bk-{{ section.id }} .bk-headline em {
  display: block;
  font-style: normal;
  color: var(--bk-accent);
}

/* ══ Body Text ══════════════════════════ */
#bk-{{ section.id }} .bk-body {
  color: var(--bk-dim);
  font-size: clamp(14px,1.2vw,16.5px);
  line-height: 1.7;
  max-width: 640px;
  margin: 0;
}
#bk-{{ section.id }} .bk-body strong { color: var(--bk-text); }

/* ══ Mobile Image ═══════════════════════ */
#bk-{{ section.id }} .bk-img-mobile {
  display: block;
  border-radius: 14px;
  overflow: hidden;
  margin: 16px 0;
  position: relative;
}
@media(min-width:1024px) { #bk-{{ section.id }} .bk-img-mobile { display: none } }
#bk-{{ section.id }} .bk-img-mobile img {
  width: 100%;
  aspect-ratio: 16 / 9;
  object-fit: cover;
  display: block;
}
#bk-{{ section.id }} .bk-img-mobile-fade {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(26,14,5,0.5) 0%, transparent 40%);
  pointer-events: none;
}

/* ══ Desktop Image ══════════════════════ */
#bk-{{ section.id }} .bk-img-desktop {
  display: none;
  position: relative;
}
@media(min-width:1024px) { #bk-{{ section.id }} .bk-img-desktop { display: block } }

#bk-{{ section.id }} .bk-img-desktop-inner {
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 30px 80px -20px rgba(28,14,5,0.7);
  will-change: transform;
}
#bk-{{ section.id }} .bk-img-desktop img {
  width: 100%;
  aspect-ratio: 4 / 3;
  object-fit: cover;
  display: block;
}
#bk-{{ section.id }} .bk-img-desktop-fade {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(26,14,5,0.4) 0%, transparent 30%);
  pointer-events: none;
}
#bk-{{ section.id }} .bk-img-desktop-glow {
  position: absolute;
  inset: -32px;
  z-index: -1;
  border-radius: 24px;
  opacity: 0.15;
  background: radial-gradient(ellipse at center, rgba({{ ar }},{{ ag }},{{ ab }},0.3), transparent 70%);
  filter: blur(40px);
  pointer-events: none;
}
#bk-{{ section.id }} .bk-img-ph {
  width: 100%;
  aspect-ratio: 4 / 3;
  border: 2px dashed var(--bk-border);
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--bk-dim);
  font-size: 32px;
}

/* ══ Facts Row ══════════════════════════ */
#bk-{{ section.id }} .bk-facts {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12px;
  margin-bottom: 14px;
}
@media(min-width:600px) { #bk-{{ section.id }} .bk-facts { grid-template-columns: repeat(3,1fr) } }

#bk-{{ section.id }} .bk-fact {
  background: var(--bk-card);
  border: 1px solid var(--bk-border);
  border-radius: 12px;
  padding: 20px 18px 18px;
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  position: relative;
  overflow: hidden;
}
#bk-{{ section.id }} .bk-fact-line {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--bk-accent), transparent 70%);
  opacity: 0.7;
}
#bk-{{ section.id }} .bk-fact-val-row {
  display: flex;
  align-items: baseline;
  gap: 5px;
  margin-bottom: 6px;
}
#bk-{{ section.id }} .bk-fact-val {
  font-size: 28px;
  font-weight: 800;
  font-style: italic;
  color: var(--bk-accent);
  line-height: 1;
}
@media(min-width:768px) { #bk-{{ section.id }} .bk-fact-val { font-size: 38px } }
#bk-{{ section.id }} .bk-fact-unit {
  font-size: 11px;
  color: var(--bk-muted);
}
@media(min-width:768px) { #bk-{{ section.id }} .bk-fact-unit { font-size: 13px } }
#bk-{{ section.id }} .bk-fact-label {
  font-size: 12px;
  font-weight: 600;
  color: var(--bk-text);
  margin: 0 0 4px;
}
@media(min-width:768px) { #bk-{{ section.id }} .bk-fact-label { font-size: 13px } }
#bk-{{ section.id }} .bk-fact-sub {
  font-size: 11px;
  color: var(--bk-dim);
  line-height: 1.55;
  margin: 0;
}

/* ══ Cards Grid ═════════════════════════ */
#bk-{{ section.id }} .bk-cards {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14px;
}
@media(min-width:768px) { #bk-{{ section.id }} .bk-cards { grid-template-columns: repeat(2,1fr) } }

/* Base Card */
#bk-{{ section.id }} .bk-card {
  background: var(--bk-card);
  border: 1px solid var(--bk-border);
  border-radius: 12px;
  padding: 20px 20px 18px;
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  position: relative;
  overflow: hidden;
  min-width: 0;
}

/* Top Accent Line */
#bk-{{ section.id }} .bk-card-line {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  opacity: 0.7;
}
#bk-{{ section.id }} .bk-card-line--amber { background: linear-gradient(90deg, var(--bk-accent), transparent 70%) }
#bk-{{ section.id }} .bk-card-line--blue  { background: linear-gradient(90deg, var(--bk-blue),   transparent 70%) }

/* Card Header (Icon + Label/Title stack) */
#bk-{{ section.id }} .bk-card-hdr {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 12px;
}
#bk-{{ section.id }} .bk-card-icon { font-size: 16px; flex-shrink: 0 }
#bk-{{ section.id }} .bk-card-label {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  display: block;
  line-height: 1.3;
}
#bk-{{ section.id }} .bk-card-label--amber { color: var(--bk-accent) }
#bk-{{ section.id }} .bk-card-label--blue  { color: var(--bk-blue)   }
#bk-{{ section.id }} .bk-card-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--bk-text);
  line-height: 1.2;
  margin: 0;
  word-break: break-word;
}

/* ── Rotation Rows ───────────────────── */
#bk-{{ section.id }} .bk-rot-rows { display: flex; flex-direction: column; gap: 5px }
#bk-{{ section.id }} .bk-rot-row {
  display: flex;
  align-items: center;
  gap: 10px;
  background: var(--bk-row);
  border-radius: 7px;
  padding: 7px 10px;
  min-width: 0;
}
#bk-{{ section.id }} .bk-rot-dot   { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0 }
#bk-{{ section.id }} .bk-rot-lbl   { font-size: 11.5px; font-weight: 600; color: var(--bk-text); flex: 1; min-width: 0 }
#bk-{{ section.id }} .bk-rot-nutr  { font-size: 10px; color: var(--bk-muted); white-space: nowrap; flex-shrink: 0 }
@media(max-width:479px) { #bk-{{ section.id }} .bk-rot-nutr { display: none } }
#bk-{{ section.id }} .bk-rot-note  { font-size: 10.5px; color: var(--bk-accent); margin-top: 12px; font-family: monospace }

/* ── Card Body Text ──────────────────── */
#bk-{{ section.id }} .bk-card-body {
  font-size: 11.5px;
  color: var(--bk-dim);
  line-height: 1.55;
  margin: 0 0 10px;
}
#bk-{{ section.id }} .bk-card-body strong { color: var(--bk-text) }

/* ── Supplement Rows ─────────────────── */
#bk-{{ section.id }} .bk-sup-row {
  display: flex;
  align-items: center;
  gap: 10px;
  border-radius: 8px;
  padding: 7px 10px;
  margin-bottom: 5px;
  min-width: 0;
}
#bk-{{ section.id }} .bk-sup-row--blue  { background: rgba(92,163,203,0.04);              border: 1px solid rgba(92,163,203,0.10)              }
#bk-{{ section.id }} .bk-sup-row--amber { background: rgba({{ ar }},{{ ag }},{{ ab }},0.04); border: 1px solid rgba({{ ar }},{{ ag }},{{ ab }},0.10) }
#bk-{{ section.id }} .bk-sup-row--green { background: rgba(90,158,90,0.04);               border: 1px solid rgba(90,158,90,0.10)               }
#bk-{{ section.id }} .bk-sup-emoji   { font-size: 14px; flex-shrink: 0 }
#bk-{{ section.id }} .bk-sup-name    { font-size: 12px; font-weight: 600; color: var(--bk-text); white-space: nowrap }
#bk-{{ section.id }} .bk-sup-detail  { font-size: 10px; color: var(--bk-muted) }
#bk-{{ section.id }} .bk-sup-examples{ font-size: 10px; color: var(--bk-dim); margin-left: auto; white-space: nowrap }
@media(max-width:479px) { #bk-{{ section.id }} .bk-sup-examples { display: none } }

/* ── Status Badge ────────────────────── */
#bk-{{ section.id }} .bk-status-badge {
  display: flex;
  align-items: center;
  gap: 8px;
  border-radius: 8px;
  padding: 6px 10px;
  font-size: 11px;
  font-weight: 600;
  margin-top: 8px;
}
#bk-{{ section.id }} .bk-status-badge--blue {
  background: rgba(92,163,203,0.06);
  border: 1px solid rgba(92,163,203,0.12);
  color: var(--bk-blue);
}

/* ── Welpen Accordion ────────────────── */
#bk-{{ section.id }} .bk-welp-toggle {
  width: 100%;
  text-align: left;
  margin-top: 8px;
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
  color: var(--bk-muted);
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px 0;
  font-family: inherit;
  transition: color .2s;
}
#bk-{{ section.id }} .bk-welp-toggle:hover { color: var(--bk-text) }
#bk-{{ section.id }} .bk-welp-arrow { display: inline-block; transition: transform .3s }
#bk-{{ section.id }} .bk-welp-toggle.bk-open .bk-welp-arrow { transform: rotate(90deg) }
#bk-{{ section.id }} .bk-welp-body {
  max-height: 0;
  opacity: 0;
  overflow: hidden;
  transition: max-height .4s ease, opacity .3s ease;
}
#bk-{{ section.id }} .bk-welp-body p {
  font-size: 10.5px;
  color: var(--bk-dim);
  line-height: 1.5;
  margin: 8px 0 0;
  padding-left: 14px;
  border-left: 2px solid rgba(92,163,203,0.2);
}

/* ── Fazit Card ──────────────────────── */
#bk-{{ section.id }} .bk-fazit-card {
  background: linear-gradient(135deg, rgba({{ ar }},{{ ag }},{{ ab }},0.08) 0%, var(--bk-card) 100%) !important;
  border-color: rgba({{ ar }},{{ ag }},{{ ab }},0.15) !important;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
#bk-{{ section.id }} .bk-fazit-glow {
  position: absolute;
  bottom: -24px; right: -24px;
  width: 128px; height: 128px;
  opacity: 0.05;
  background: radial-gradient(circle, rgba({{ ar }},{{ ag }},{{ ab }},1), transparent 70%);
  pointer-events: none;
}
#bk-{{ section.id }} .bk-fazit-title {
  font-size: 17px;
  font-weight: 700;
  color: var(--bk-text);
  line-height: 1.2;
  margin: 0 0 14px;
}
@media(min-width:768px) { #bk-{{ section.id }} .bk-fazit-title { font-size: 19px } }
#bk-{{ section.id }} .bk-fazit-title em { font-style: normal; color: var(--bk-accent) }

#bk-{{ section.id }} .bk-check-rows { display: flex; flex-direction: column; gap: 5px }
#bk-{{ section.id }} .bk-check-row  { display: flex; align-items: center; gap: 8px; font-size: 11.5px; color: var(--bk-dim) }
#bk-{{ section.id }} .bk-check-tick { color: var(--bk-accent); flex-shrink: 0 }
</style>

<div id="bk-{{ section.id }}" data-bk-bg="{{ bg_style }}">
  <!-- Paw-Pattern (via JS, nur bei paw_light / paw_dark) -->
  <div class="bk-paws-ctn" aria-hidden="true"></div>

  <div class="bk-inner">

    <!-- ── Hero: Badge + Headline + Bild + Text ── -->
    <div class="bk-hero">
      <div class="bk-hero-text">

        {%- if section.settings.badge != blank -%}
          <div class="bk-badge">{{ section.settings.badge }}</div>
        {%- endif -%}

        <h2 class="bk-headline">
          {{ section.settings.headline | default: 'Die perfekte Basis.' }}
          <em>{{ section.settings.headline_acc | default: 'Für jeden Hund.' }}</em>
        </h2>

        <!-- Bild: nur Mobile (zwischen Headline und Text) -->
        {%- if section.settings.image -%}
          <div class="bk-img-mobile">
            <img src="{{ section.settings.image | image_url: width: 900 }}"
                 alt="{{ section.settings.image_alt | default: '' }}"
                 width="{{ section.settings.image.width }}"
                 height="{{ section.settings.image.height }}"
                 loading="lazy" decoding="async">
            <div class="bk-img-mobile-fade"></div>
          </div>
        {%- endif -%}

        {%- if section.settings.body != blank -%}
          <p class="bk-body">{{ section.settings.body }}</p>
        {%- endif -%}
      </div>

      <!-- Bild: nur Desktop (Parallax) -->
      <div class="bk-img-desktop" data-bk-parallax="0.02">
        {%- if section.settings.image -%}
          <div class="bk-img-desktop-inner">
            <img src="{{ section.settings.image | image_url: width: 1000 }}"
                 alt="{{ section.settings.image_alt | default: '' }}"
                 width="{{ section.settings.image.width }}"
                 height="{{ section.settings.image.height }}"
                 loading="lazy" decoding="async">
            <div class="bk-img-desktop-fade"></div>
          </div>
          <div class="bk-img-desktop-glow"></div>
        {%- else -%}
          <div class="bk-img-ph">📸</div>
        {%- endif -%}
      </div>
    </div><!-- /.bk-hero -->

    <!-- ── Fakten-Kacheln (3 Spalten) ── -->
    <div class="bk-facts">

      <div class="bk-fact">
        <div class="bk-fact-line"></div>
        <div class="bk-fact-val-row">
          <span class="bk-fact-val">{{ section.settings.fact1_value | default: '35' }}</span>
          <span class="bk-fact-unit">{{ section.settings.fact1_unit  | default: '%' }}</span>
        </div>
        <p class="bk-fact-label">{{ section.settings.fact1_label | default: 'Mehr Bioverfügbarkeit' }}</p>
        <p class="bk-fact-sub">{{ section.settings.fact1_sub | default: 'Natürliche Vitamine mit Enzymen und Co-Faktoren · kein Labor baut das nach.' }}</p>
      </div>

      <div class="bk-fact">
        <div class="bk-fact-line"></div>
        <div class="bk-fact-val-row">
          <span class="bk-fact-val">{{ section.settings.fact2_value | default: '0' }}</span>
          <span class="bk-fact-unit">{{ section.settings.fact2_unit  | default: 'Zusätze' }}</span>
        </div>
        <p class="bk-fact-label">{{ section.settings.fact2_label | default: 'Keine Synthetik' }}</p>
        <p class="bk-fact-sub">{{ section.settings.fact2_sub | default: 'Kein Rohöl-Cracking, keine GVO-Bakterien. Nichts zugesetzt, nichts nötig.' }}</p>
      </div>

      <div class="bk-fact">
        <div class="bk-fact-line"></div>
        <div class="bk-fact-val-row">
          <span class="bk-fact-val">{{ section.settings.fact3_value | default: '2' }}</span>
          <span class="bk-fact-unit">{{ section.settings.fact3_unit  | default: 'Handgriffe' }}</span>
        </div>
        <p class="bk-fact-label">{{ section.settings.fact3_label | default: 'Vollständig bedarfsdeckend' }}</p>
        <p class="bk-fact-sub">{{ section.settings.fact3_sub | default: 'Öl + Jod täglich. Kein Plan, keine Tabelle.' }}</p>
      </div>

    </div><!-- /.bk-facts -->

    <!-- ── Info-Karten 2×2 Grid ── -->
    <div class="bk-cards">

      <!-- ─ Karte 1: Rotation ─ -->
      <div class="bk-card">
        <div class="bk-card-line bk-card-line--amber"></div>
        <div class="bk-card-hdr">
          <span class="bk-card-icon">{{ section.settings.rot_icon | default: '📅' }}</span>
          <div>
            <span class="bk-card-label bk-card-label--amber">{{ section.settings.rot_label | default: "SO GEHT'S" }}</span>
            <p class="bk-card-title">{{ section.settings.rot_title | default: '3 / 3 / 1 Rotation' }}</p>
          </div>
        </div>
        <div class="bk-rot-rows">
          <div class="bk-rot-row">
            <span class="bk-rot-dot" style="background:var(--bk-red)"></span>
            <span class="bk-rot-lbl">{{ section.settings.rot_row1_label  | default: '3× Rotes Fleisch' }}</span>
            <span class="bk-rot-nutr">{{ section.settings.rot_row1_nutr  | default: 'Eisen · B12 · Taurin' }}</span>
          </div>
          <div class="bk-rot-row">
            <span class="bk-rot-dot" style="background:hsl(47,78%,52%)"></span>
            <span class="bk-rot-lbl">{{ section.settings.rot_row2_label  | default: '3× Helles Fleisch' }}</span>
            <span class="bk-rot-nutr">{{ section.settings.rot_row2_nutr  | default: 'Omega-6 · Lysin' }}</span>
          </div>
          <div class="bk-rot-row">
            <span class="bk-rot-dot" style="background:var(--bk-blue)"></span>
            <span class="bk-rot-lbl">{{ section.settings.rot_row3_label  | default: '1× Fisch' }}</span>
            <span class="bk-rot-nutr">{{ section.settings.rot_row3_nutr  | default: 'DHA · EPA · Omega-3' }}</span>
          </div>
        </div>
        {%- if section.settings.rot_note != blank -%}
          <p class="bk-rot-note">{{ section.settings.rot_note }}</p>
        {%- endif -%}
      </div>

      <!-- ─ Karte 2: Allergie / Sensibel ─ -->
      <div class="bk-card">
        <div class="bk-card-line bk-card-line--blue"></div>
        <div class="bk-card-hdr">
          <span class="bk-card-icon">{{ section.settings.all_icon | default: '🔄' }}</span>
          <div>
